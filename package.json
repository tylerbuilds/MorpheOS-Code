{
  "name": "deepseek-harness",
  "version": "0.0.1",
  "description": "Local-first, safety-gated CLI and MCP harness for bounded DeepSeek batch and corpus workloads.",
  "private": true,
  "license": "MIT",
  "author": "DeepSeek Harness contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tylerbuilds/deepseek-harness.git"
  },
  "bugs": {
    "url": "https://github.com/tylerbuilds/deepseek-harness/issues"
  },
  "homepage": "https://github.com/tylerbuilds/deepseek-harness#readme",
  "keywords": [
    "deepseek",
    "mcp",
    "llm",
    "batch-processing",
    "ocr",
    "translation",
    "local-first"
  ],
  "type": "module",
  "bin": {
    "deepseek-harness": "./dist/src/cli.js",
    "deepseek-harness-mcp": "./dist/src/mcp.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/test/*.test.js",
    "test:e2e": "npm run build && node --test dist/test/e2e.test.js",
    "doctor": "node dist/src/cli.js doctor",
    "install:local": "bash scripts/install-local.sh",
    "mcp:config": "node dist/src/cli.js mcp-config",
    "mcp:config:codex": "node dist/src/cli.js mcp-config --format codex-toml",
    "mcp:smoke": "node scripts/smoke-mcp.mjs",
    "pack:check": "npm run build && node scripts/check-package-contents.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist/",
    "examples/",
    "scripts/install-local.sh",
    "scripts/smoke-mcp.mjs",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "docs/user-guide.md",
    "docs/corpus-heavy-workloads.md"
  ]
}
